{% extends "layout.jinja2" %}
{% block title %}Settings{% endblock %}

{% block main %}

    <a class="back-link" href="/panel/">Back to panel</a>

    <section class="page-head compact">
        <div class="page-copy">
            <h1>{{ server['namecache'] }}</h1>
            <p class="lead">Adjust the main guild-wide Rosettes settings from one place.</p>
        </div>
    </section>

    <form method="POST" action="/action/{{ server['id'] }}/update-settings">
        {{ csrf_input()|safe }}
        <div class="stack">
            <div class="block bottom-pad">
                <h4>Message parsing</h4>
                <p class="helper-text">
                    Rosettes can parse supported links and references to provide short useful information, such as Steam games,
                    Steam profiles, and mirrored 4cdn media.<br>
                    <small>Rosettes never stores any message data whatsoever.</small>
                </p>
                <select name="msgparse">
                    <option value="1">Enabled</option>
                    <option value="0" {% if not msgparse %} selected {% endif %}>Disabled</option>
                </select>
            </div>

            <div class="block bottom-pad">
                <h4>Farm minigame</h4>
                <p class="helper-text">
                    Toggles the commands under <code>/farm</code>.<br>
                    <small>If needed, you can still limit usage to one channel with <code>/setfarmchan</code>.</small>
                </p>
                <select name="minigame">
                    <option value="1">Enabled</option>
                    <option value="0" {% if not minigame %} selected {% endif %}>Disabled</option>
                </select>
            </div>

            <div class="block bottom-pad">
                <h4>Voice chat announce</h4>
                <p class="helper-text">
                    If enabled, Rosettes announces when someone joins or leaves a voice channel in that channel’s text chat.<br>
                    <small>Each message is deleted after 60 seconds to keep things tidy.</small>
                </p>
                <select name="announce">
                    <option value="1">Enabled</option>
                    <option value="0" {% if not announce %} selected {% endif %}>Disabled</option>
                </select>
            </div>
        </div>

        <div class="form-actions">
            <input type="submit" value="Save settings">
            <a class="menu-button secondary" href="/panel/">Cancel</a>
        </div>
    </form>

    <div class="block soft" style="margin-top:.75rem;">
        <h4>Additional configuration</h4>
        <p class="helper-text"><code>/setlogchan</code> sets the channel where Rosettes announces when someone joins or leaves the server.</p>
    </div>

{% endblock %}
