{% extends "layout.jinja2" %}
{% block title %}Settings{% endblock %}

{% block main %}

    <a class="back-link" href="/panel/">Back to panel</a>

    <section class="page-head compact">
        <div class="page-copy">
            <h1>{{ server['namecache'] }}</h1>
            <p class="lead">Adjust the main guild-wide Rosettes settings from one place.</p>
        </div>
    </section>

    {% if not bot_reachable %}
        <p class="inline-note">The bot API is unreachable, so channel and role names are not available. You can still enter Discord IDs manually below.</p>
    {% endif %}

    <form method="POST" action="/action/{{ server['id'] }}/update-settings">
        {{ csrf_input()|safe }}
        <div class="stack">
            <div class="block bottom-pad">
                <h4>Message parsing</h4>
                <p class="helper-text">
                    Rosettes can parse supported links and references to provide short useful information, such as Steam games,
                    Steam profiles, and mirrored 4cdn media.<br>
                    <small>Rosettes never stores any message data whatsoever.</small>
                </p>
                <div class="form-row">
                    <select name="msgparse">
                        <option value="1">Enabled</option>
                        <option value="0" {% if not msgparse %} selected {% endif %}>Disabled</option>
                    </select>
                </div>
            </div>

            <div class="block bottom-pad">
                <h4>Random commands</h4>
                <p class="helper-text">
                    Toggles the <code>/random</code> family of commands. These fetch light, ephemeral content like images and short quotes.<br>
                    <small>Independent from message parsing and the farm minigame.</small>
                </p>
                <div class="form-row">
                    <select name="random">
                        <option value="1">Enabled</option>
                        <option value="0" {% if not random_cmds %} selected {% endif %}>Disabled</option>
                    </select>
                </div>
            </div>

            <div class="block bottom-pad">
                <h4>Dumb commands</h4>
                <p class="helper-text">
                    Toggles the <code>/dumb</code> family of commands. These are non-serious, novelty responses.<br>
                    <small>Independent from message parsing and the farm minigame.</small>
                </p>
                <div class="form-row">
                    <select name="dumb">
                        <option value="1">Enabled</option>
                        <option value="0" {% if not dumb_cmds %} selected {% endif %}>Disabled</option>
                    </select>
                </div>
            </div>

            <div class="block bottom-pad">
                <h4>Farm minigame</h4>
                <p class="helper-text">
                    Toggles the commands under <code>/farm</code>.<br>
                    <small>If needed, you can still limit usage to one channel.</small>
                </p>
                <div class="form-row">
                    <select name="minigame">
                        <option value="1">Enabled</option>
                        <option value="0" {% if not minigame %} selected {% endif %}>Disabled</option>
                    </select>
                </div>
            </div>

            <div class="block bottom-pad">
                <h4>Voice chat announce</h4>
                <p class="helper-text">
                    If enabled, Rosettes announces when someone joins or leaves a voice channel in that channel’s text chat.<br>
                    <small>Each message is deleted after 60 seconds to keep things tidy.</small>
                </p>
                <div class="form-row">
                    <select name="announce">
                        <option value="1">Enabled</option>
                        <option value="0" {% if not announce %} selected {% endif %}>Disabled</option>
                    </select>
                </div>
            </div>

            <div class="block bottom-pad">
                <h4>Default role on join</h4>
                <p class="helper-text">
                    The role Rosettes assigns to new members when they join the server.<br>
                    <small>Leave as <em>none</em> to skip auto-assignment.</small>
                </p>
                <div class="form-row">
                    {% if roles %}
                        <select name="defaultrole">
                            <option value="0">None</option>
                            {% for role in roles %}
                                {% if not role['isEveryone'] %}
                                    <option value="{{ role['id'] }}" {% if role['id'] == defaultrole %} selected {% endif %}>{{ role['name'] }}</option>
                                {% endif %}
                            {% endfor %}
                        </select>
                    {% else %}
                        <input type="number" name="defaultrole" min="0" value="{{ defaultrole }}" placeholder="Discord role ID">
                    {% endif %}
                </div>
            </div>

            <div class="block bottom-pad">
                <h4>Join/leave log channel</h4>
                <p class="helper-text">
                    The channel where Rosettes announces when someone joins or leaves the server.<br>
                </p>
                <div class="form-row">
                    {% if channels %}
                        <select name="logchannel">
                            <option value="0">None</option>
                            {% for channel in channels %}
                                {% if channel['type'] == 'text' %}
                                    <option value="{{ channel['id'] }}" {% if channel['id'] == logchannel %} selected {% endif %}>#{{ channel['name'] }}</option>
                                {% endif %}
                            {% endfor %}
                        </select>
                    {% else %}
                        <input type="number" name="logchannel" min="0" value="{{ logchannel }}" placeholder="Discord channel ID">
                    {% endif %}
                </div>
            </div>

            <div class="block bottom-pad">
                <h4>Farm channel</h4>
                <p class="helper-text">
                    If set, <code>/farm</code> can only be used in this channel. Leave as <em>none</em> to allow farming anywhere the farm minigame is enabled.<br>
                    <small>Only text channels are listed.</small>
                </p>
                <div class="form-row">
                    {% if channels %}
                        <select name="farmchannel">
                            <option value="0">None</option>
                            {% for channel in channels %}
                                {% if channel['type'] == 'text' %}
                                    <option value="{{ channel['id'] }}" {% if channel['id'] == farmchannel %} selected {% endif %}>#{{ channel['name'] }}</option>
                                {% endif %}
                            {% endfor %}
                        </select>
                    {% else %}
                        <input type="number" name="farmchannel" min="0" value="{{ farmchannel }}" placeholder="Discord channel ID">
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="form-actions">
            <input type="submit" value="Save settings">
            <a class="menu-button secondary" href="/panel/">Cancel</a>
        </div>
    </form>

{% endblock %}
