{% extends "layout.jinja2" %}
{% block title %}{{ app['name'] }}{% endblock %}

{% block main %}

    <a class="back-link" href="/panel/">Back to panel</a>

    <section class="page-head compact">
        <div class="page-copy">
            <h1>{{ app['name'] }}</h1>
            <p class="lead">Application details, authorized users, and API information.</p>
        </div>
        <form method="POST" action="/action/delete-app/{{ app['id'] }}"
              onsubmit="return confirm('Delete this application? This will also remove its user authorizations.');">
            <button type="submit" class="entry-remove">Delete application</button>
        </form>
    </section>

    <div class="stack">
        <div class="block">
            <div class="info-grid">
                <div>
                    <p class="muted">Application ID</p>
                    <p><strong>#{{ app['id'] }}</strong></p>
                </div>
                <div>
                    <p class="muted">Token</p>
                    <p><code class="token">{{ app['token_key'] }}</code></p>
                </div>
            </div>
        </div>

        <div class="block">
            <h3>Authorized users</h3>
            <div class="inline-list spaced-list">
                {% for user in users %}
                    <div class="block soft">
                        <p><strong>{{ user['namecache'] }}</strong></p>
                        <p class="muted">Username: {{ user['username'] }}</p>
                        <p class="muted">User ID: {{ user['id'] }}</p>
                    </div>
                {% else %}
                    <p class="muted">No user has yet approved your application for auth.</p>
                {% endfor %}
            </div>
        </div>

        <div class="block stack-tight">
            <h3>Endpoints</h3>
            <p class="helper-text">Largely WIP, probably unstable. All under <code>https://rosettes.markski.ar/api/</code></p>
            <ul class="endpoint-list">
                <li><strong>[POST] request</strong> — Request authorization from a user. Params: <code>applicationKey</code>, <code>userId</code></li>
                <li><strong>[POST] notify</strong> — Send a message to a user. Params: <code>applicationKey</code>, <code>userId</code>, <code>message</code></li>
                <li><strong>[GET] user</strong> — Get user data, if authorized. Params: <code>applicationKey</code>, <code>userId</code></li>
            </ul>
            <p class="helper-text">Currently the only way to check if a user accepted auth is by polling <code>user</code>.</p>
        </div>
    </div>
{% endblock %}
