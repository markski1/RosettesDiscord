{% extends "layout.jinja2" %}
{% block title %}Creating autoroles{% endblock %}

{% block main %}

    <p><a class="menu-button" href="/panel/">Go back</a></p>

    <h3>Creating an Autoroles profile for {{ server['namecache'] }}</h3>
    <p class="muted">Pick an emoji and a role, then click <b>Add</b>. Members who react with the emoji
        on the posted message will be granted the matching role.</p>

    <form id="autoForm" method="POST" action="/action/{{ server.id }}/create-autoroles">
        {{ csrf_input()|safe }}

        <div class="block">
            <label>Profile name<br>
                <input type="text" name="name" id="profileName" placeholder="e.g. Game roles" maxlength="64" autocomplete="off">
            </label>
        </div>

        <div class="block">
            <div class="builder-row">
                <div class="emoji-field">
                    <button type="button" id="emojiTrigger" class="menu-button">Pick emoji</button>
                    <span id="emojiChosen" class="emoji-chosen" aria-label="selected emoji">—</span>

                    <div id="emojiPanel" class="emoji-panel" hidden>
                        <input type="text" id="emojiSearch" placeholder="Search emoji…" autocomplete="off">
                        <div id="emojiTabs" class="emoji-tabs"></div>
                        <div id="emojiGrid" class="emoji-grid"></div>
                    </div>
                </div>

                <select id="roleSelect">
                    <option value="0">Choose a role…</option>
                    {% for role in roles %}
                        <option value="{{ role.id }}">{{ role.rolename }}</option>
                    {% endfor %}
                </select>

                <button type="button" id="addBtn" class="menu-button" onclick="addSelection()">Add</button>
            </div>
            <p class="muted" style="margin:.5rem 0 0;"><small><span id="slotsLeft">20</span> slots left.</small></p>
        </div>

        <div class="block">
            <p class="block-title">Entries</p>
            <ul id="entryList" class="entry-list">
                <li class="muted" id="emptyHint">No roles added yet.</li>
            </ul>
        </div>

        <textarea hidden name="RoleListJson" id="RoleListJson"></textarea>
        <p id="formMsg" class="form-msg" hidden></p>
        <input type="submit" id="submitBtn" value="Create Autoroles">
        <a id="doneLink" class="menu-button" href="/panel/" hidden>Back to panel</a>
    </form>

    <script type="text/javascript">
        const maxEntries = 20;
        const entries = [];
        let selectedEmoji = null;
        let emojiData = null;
        let activeCategory = null;

        const categoryIcons = {
            "Smileys & People": "😀",
            "Animals & Nature": "🐵",
            "Travel & Places": "🌍",
            "Activities": "⚽",
            "Objects": "💡",
            "Symbols": "❤️",
            "Flags": "🏁"
        };

        const $ = (id) => document.getElementById(id);

        // --- Emoji picker -------------------------------------------------

        async function loadEmojis() {
            if (emojiData) return;
            const res = await fetch("{{ url_for('static', filename='full-emoji-list.json') }}");
            emojiData = await res.json();
            activeCategory = Object.keys(emojiData)[0];
            buildTabs();
            renderGrid();
        }

        function buildTabs() {
            const tabs = $("emojiTabs");
            tabs.innerHTML = "";
            for (const cat of Object.keys(emojiData)) {
                const b = document.createElement("button");
                b.type = "button";
                b.className = "emoji-tab" + (cat === activeCategory ? " active" : "");
                b.title = cat;
                b.textContent = categoryIcons[cat] || "•";
                b.onclick = () => {
                    activeCategory = cat;
                    $("emojiSearch").value = "";
                    buildTabs();
                    renderGrid();
                };
                tabs.appendChild(b);
            }
        }

        function matches(item, query) {
            if (item.description && item.description.toLowerCase().includes(query)) return true;
            return (item.keywords || []).some(k => k.toLowerCase().includes(query));
        }

        function renderGrid() {
            const grid = $("emojiGrid");
            const query = $("emojiSearch").value.trim().toLowerCase();
            grid.innerHTML = "";

            let items;
            if (query) {
                items = [];
                for (const cat of Object.keys(emojiData)) {
                    for (const item of emojiData[cat]) {
                        if (matches(item, query)) items.push(item);
                        if (items.length >= 240) break;
                    }
                }
            } else {
                items = emojiData[activeCategory];
            }

            if (items.length === 0) {
                grid.innerHTML = '<p class="muted" style="grid-column:1/-1;margin:.5rem;">No emoji found.</p>';
                return;
            }

            const frag = document.createDocumentFragment();
            for (const item of items) {
                const b = document.createElement("button");
                b.type = "button";
                b.textContent = item.emoji;
                b.title = (item.description || "").split("≊")[0].trim();
                b.onclick = () => chooseEmoji(item.emoji);
                frag.appendChild(b);
            }
            grid.appendChild(frag);
        }

        function chooseEmoji(emoji) {
            selectedEmoji = emoji;
            $("emojiChosen").textContent = emoji;
            togglePanel(false);
        }

        function togglePanel(show) {
            const panel = $("emojiPanel");
            const willShow = show === undefined ? panel.hidden : show;
            panel.hidden = !willShow;
            if (willShow) loadEmojis();
        }

        $("emojiTrigger").addEventListener("click", () => togglePanel());
        $("emojiSearch").addEventListener("input", renderGrid);

        document.addEventListener("click", (e) => {
            if (!$("emojiPanel").contains(e.target) && e.target !== $("emojiTrigger")) {
                $("emojiPanel").hidden = true;
            }
        });

        // --- Entry management ---------------------------------------------

        function addSelection() {
            const roleSelect = $("roleSelect");
            const roleId = roleSelect.value;
            const roleName = roleSelect.options[roleSelect.selectedIndex].text;

            if (!selectedEmoji) { alert("Pick an emoji first."); return; }
            if (roleId === "0") { alert("Choose a role first."); return; }
            if (entries.length >= maxEntries) { alert("You can add at most " + maxEntries + " roles."); return; }
            if (entries.some(e => e.roleEmoji === selectedEmoji)) { alert("That emoji is already used. Pick a different one."); return; }
            if (entries.some(e => e.roleId === roleId)) { alert("That role is already in the list."); return; }

            entries.push({ roleId: roleId, roleName: roleName, roleEmoji: selectedEmoji });

            selectedEmoji = null;
            $("emojiChosen").textContent = "—";
            roleSelect.value = "0";
            render();
        }

        function removeEntry(index) {
            entries.splice(index, 1);
            render();
        }

        function render() {
            const list = $("entryList");
            list.innerHTML = "";

            if (entries.length === 0) {
                const li = document.createElement("li");
                li.className = "muted";
                li.textContent = "No roles added yet.";
                list.appendChild(li);
            } else {
                entries.forEach((entry, i) => {
                    const li = document.createElement("li");

                    const emoji = document.createElement("span");
                    emoji.className = "e-emoji";
                    emoji.textContent = entry.roleEmoji;

                    const role = document.createElement("span");
                    role.className = "e-role";
                    role.textContent = entry.roleName;

                    const remove = document.createElement("button");
                    remove.type = "button";
                    remove.className = "entry-remove";
                    remove.textContent = "Remove";
                    remove.onclick = () => removeEntry(i);

                    li.append(emoji, role, remove);
                    list.appendChild(li);
                });
            }

            $("slotsLeft").textContent = maxEntries - entries.length;
            $("RoleListJson").value = JSON.stringify(entries);
        }

        function setMsg(text, kind) {
            const el = $("formMsg");
            el.textContent = text;
            el.className = "form-msg" + (kind ? " " + kind : "");
            el.hidden = !text;
        }

        $("autoForm").addEventListener("submit", async (e) => {
            e.preventDefault();

            if (entries.length === 0) { setMsg("Add at least one role before creating.", "err"); return; }
            if ($("profileName").value.trim().length === 0) { setMsg("Give the profile a name.", "err"); return; }

            const form = e.target;
            const btn = $("submitBtn");
            btn.disabled = true;
            setMsg("Creating…", "");

            try {
                const res = await fetch(form.action, {
                    method: "POST",
                    headers: { "Accept": "application/json" },
                    body: new FormData(form)
                });
                let data = {};
                try { data = await res.json(); } catch (_) {}

                if (res.ok && data.ok) {
                    // Success: lock the form so it can't be double-submitted, but the
                    // page stays put with a confirmation rather than navigating away.
                    setMsg(data.message || "Autorole group created successfully.", "ok");
                    btn.hidden = true;
                    form.querySelectorAll("input, select, button").forEach(el => el.disabled = true);
                    $("doneLink").hidden = false;
                } else {
                    // Failure: keep every entry the user built, just surface the reason.
                    setMsg(data.message || "Something went wrong. Your entries are still here — try again.", "err");
                    btn.disabled = false;
                }
            } catch (err) {
                setMsg("Network error. Your entries are still here — try again.", "err");
                btn.disabled = false;
            }
        });

        render();
    </script>

{% endblock %}
