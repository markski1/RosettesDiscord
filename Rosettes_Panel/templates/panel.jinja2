{% extends "layout.jinja2" %}
{% block title %}Panel{% endblock %}

{% block main %}

    <div class="topbar">
        <span>Welcome, <strong>{{ user['namecache'] }}</strong></span>
        <a class="menu-button secondary" href="/session/logout">Logout</a>
    </div>

    <section class="section-head">
        <div class="page-copy">
            <h2>Servers</h2>
            <p class="muted">Server settings and autorole configuration for guilds you own.</p>
        </div>
    </section>

    <div class="card-grid">
        {% for server in servers %}
            <div class="block">
                <p class="block-title">{{ server['namecache'] }}</p>
                <div class="meta-row">
                    <span class="meta-pill">{{ server['members'] }} members</span>
                    <span class="meta-pill">Server ID {{ server['id'] }}</span>
                </div>
                <div class="actions">
                    <a class="menu-button" href="/panel/{{ server['id'] }}/settings">Settings</a>
                    <a class="menu-button secondary" href="/panel/{{ server['id'] }}/roles">Roles</a>
                </div>
            </div>
        {% else %}
            <div class="block soft">
                <p class="muted">You do not have any servers in which Rosettes has been added.</p>
            </div>
        {% endfor %}
    </div>

    <section class="section-head">
        <div class="page-copy">
            <h2>Applications</h2>
            <p class="muted">Manage app tokens and see users who have approved your integrations.</p>
        </div>
        <a class="menu-button" href="/panel/apps/new">Create application</a>
    </section>

    <div class="card-grid">
        {% for app in apps %}
            <div class="block">
                <p class="block-title">{{ app['name'] }}</p>
                <div class="meta-row">
                    <span class="meta-pill">App ID {{ app['id'] }}</span>
                </div>
                <div class="actions">
                    <a class="menu-button" href="/panel/apps/{{ app['id'] }}">Manage</a>
                </div>
            </div>
        {% else %}
            <div class="block soft">
                <p class="muted">You have no applications registered.</p>
            </div>
        {% endfor %}
    </div>

{% endblock %}
