{% extends "layout.jinja2" %}
{% block title %}Login{% endblock %}

{% block main %}

    <h1>Login</h1>

    <div class="block">
        <form action="/session/login" method="POST">
            <p>Enter your Rosettes key</p>
            <label>Key: <input type="text" name="key" autofocus /></label>
            <input type="submit" value="Log in">
        </form>
    </div>
    <p class="muted"><small>To get a key, DM Rosettes with the command '/keygen'.</small></p>

{% endblock %}
