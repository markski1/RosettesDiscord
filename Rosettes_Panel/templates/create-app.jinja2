{% extends "layout.jinja2" %}
{% block title %}Creating application{% endblock %}

{% block main %}

    <a class="back-link" href="/panel/">Back to panel</a>

    <section class="page-head compact">
        <div class="page-copy">
            <h1>Create application</h1>
            <p class="lead">Applications let you authorize and verify Discord users through Rosettes’ API.</p>
        </div>
    </section>

    <div class="block stack">
        <form method="POST" action="/action/create-app">
            <label>
                Application name
                <input type="text" name="name" placeholder="e.g. My Rosettes Integration" />
            </label>
            <div class="form-actions">
                <input type="submit" value="Create application">
            </div>
        </form>
    </div>

{% endblock %}
